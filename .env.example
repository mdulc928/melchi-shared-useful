# SvelteKit + Firebase + SendGrid + Twilio + Stripe example env file
# Copy to `.env` and fill in your values.

# Public Firebase Web SDK config (exposed to client)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-only). Do NOT prefix with PUBLIC_.
# Use the same project as the client SDK.
PRIVATE_FIREBASE_PROJECT_ID=""
PRIVATE_FIREBASE_CLIENT_EMAIL=""
# Paste the private key as a single line with literal \n and we will replace them in code.
PRIVATE_FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# SendGrid (server-only)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=you@example.com

# Mailgun (server-only)
MAILGUN_API_KEY=
MAILGUN_FROM_EMAIL=postmaster@yourdomain.com
# Optional: If not set, domain is derived from MAILGUN_FROM_EMAIL
MAILGUN_DOMAIN=
# Optional: set to https://api.eu.mailgun.net for EU regions
MAILGUN_API_URL=

# Twilio (server-only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Messaging Service SID configured for Conversations/SMS (used by Conversations)
TWILIO_MESSAGING_SERVICE_SID=
# Twilio Conversations Service SID (optional if your service default has Messaging Service set)
TWILIO_CONVERSATIONS_SERVICE_SID=
# Twilio Verify Service SID (for phone verification)
TWILIO_VERIFY_SERVICE_SID=

# Stripe (server-only)
# Create a $2.99/month Price in your Stripe Dashboard and paste its ID below (e.g., price_123)
STRIPE_SECRET_KEY=
STRIPE_MONTHLY_PRICE_ID=
# Webhook secret for verifying Stripe events (from the Stripe CLI or Dashboard)
STRIPE_WEBHOOK_SECRET=
# Optional: if later you use Stripe.js/Elements, set the publishable key here
PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cron protection (server-only)
# Scheduler must send header: x-cron-gttr-secret: <value below>
CRON_SECRET=
